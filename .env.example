# Copia este archivo a .env y rellena la API key del proveedor que vayas a usar.
# docker compose lee .env automáticamente.

# Proveedor de IA: anthropic (por defecto) u openai.
COACH_LLM_PROVIDER=anthropic

# --- Si usas Anthropic (proveedor por defecto) ---
ANTHROPIC_API_KEY=sk-ant-...
# Opcional: cambiar de modelo (por defecto claude-opus-4-8)
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Si usas OpenAI (COACH_LLM_PROVIDER=openai) ---
# OPENAI_API_KEY=sk-...
# Opcional: cambiar de modelo (por defecto gpt-4o)
# OPENAI_MODEL=gpt-4o
